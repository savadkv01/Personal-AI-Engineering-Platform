# PAIEP environment template (M0).
# Copy to `docker/.env` and adjust. The real `.env` is git-ignored (NFR-022).
# Only NON-SECRET defaults belong in this example — never commit real secrets.

# --- Project / profile -----------------------------------------------------
COMPOSE_PROJECT_NAME=paiep
# Active hardware/runtime profile: cpu (A/A+) | gpu (B/C) | server (D)
PAIEP_PROFILE=cpu

# --- Networking (ADR 0005 / 0006: loopback only) ---------------------------
# Host interface published services bind to. Keep 127.0.0.1 — never 0.0.0.0.
BIND_HOST=127.0.0.1

# --- M0 health probe (profile: core) ---------------------------------------
PING_HOST_PORT=8080

# --- M1 LLM runtime + gateway (profiles: inference | gateway | spike) -------
# Host ports are loopback-bound (BIND_HOST). Keep the gateway as the only
# intended public seam (ADR 0006); Ollama is published only for M1 validation.
GATEWAY_HOST_PORT=8081        # OpenAI-compatible gateway (nginx seam)
OLLAMA_HOST_PORT=11434        # Ollama LLM runtime (validation convenience)
QDRANT_HOST_PORT=6333         # M1 spike vector DB (thin; deepened in M2)

# Bearer token the gateway requires on /v1/* (auth stub, ADR 0006).
# This example value is a NON-SECRET placeholder — set a real token in .env.
GATEWAY_TOKEN=paiep-local-dev-token
# Max concurrent in-flight requests the gateway admits (concurrency stub).
GATEWAY_MAX_CONCURRENCY=4

# Default models (ADR 0004). Model-agnostic: swap here, nothing hard-codes them.
CHAT_MODEL=qwen2.5-coder:7b   # 7B Q4_K_M chat/coding default (A+ machine)
EMBED_MODEL=nomic-embed-text  # embeddings default
# How long Ollama keeps a model resident after use (avoids cold reloads).
OLLAMA_KEEP_ALIVE=30m

# Pinned image tags (offline-first; validated in M1). See ADR 0004 / 0007.
OLLAMA_IMAGE=ollama/ollama:0.6.2
GATEWAY_IMAGE=nginx:1.27-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.12.6

# --- Reserved endpoints for later milestones (single source of truth) ------
# Uncomment/adjust as each milestone lands. Ports are host-side, loopback-bound.
# POSTGRES_HOST_PORT=5432     # M5 memory / state DB
# LANGFUSE_HOST_PORT=3000     # M9 observability
# OPENWEBUI_HOST_PORT=8082    # M8 UI (optional)
